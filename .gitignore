# ============================================================
# Python 字节码 / 缓存
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# 打包产物
*.egg-info/
*.egg
.eggs/
build/
dist/

# ============================================================
# 虚拟环境
# ============================================================
.venv/
venv/
env/
.ENV/

# 环境变量 / 密钥
.env
.env.*
!.env.example

# ============================================================
# 模型权重 / 训练产物
# ============================================================
# PyTorch / 通用权重
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.pb

# 项目级训练产物目录
checkpoints/
data/
!data/.gitkeep     # 保留 data/ 目录占位文件,但忽略目录下真实数据
runs/
outputs/
logs/
*.log

# 实验追踪工具
wandb/
tensorboard/
mlruns/

# ============================================================
# Jupyter
# ============================================================
.ipynb_checkpoints/

# ============================================================
# IDE / 编辑器
# ============================================================
# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/

# Vim
*.swp
*.swo
*~

# Sublime
*.sublime-project
*.sublime-workspace

# ============================================================
# 操作系统杂项
# ============================================================
# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================
# 测试 / Lint / 类型检查 缓存
# ============================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.cache/

# ============================================================
# uv
# ============================================================
# uv.lock **不忽略** —— 它记录依赖精确版本,commit 上去保证环境可复现
# 如果你想忽略(例如纯文档项目),把下面这行的注释去掉即可
# uv.lock
